{% style %}
  #announcement-bar-{{ section.id }} {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
  }
  #announcement-bar-{{ section.id }} .announcement-bar__item {
    color: {{ section.settings.text_color }};
  }
  #announcement-bar-{{ section.id }} .announcement-bar__track {
    animation-duration: {{ section.settings.speed }}s;
  }
{% endstyle %}

{% liquid
  assign icon_truck    = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>'
  assign icon_clock    = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>'
  assign icon_star     = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  assign icon_shield   = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>'
  assign icon_check    = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
  assign icon_lightning= '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'
  assign icon_gift     = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5" rx="1"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>'
%}

<div id="announcement-bar-{{ section.id }}" class="announcement-bar full-width">
  <div class="announcement-bar__track">
    {% assign items = section.blocks | where: 'type', 'item' %}
    {% comment %}Moitié A — 4 répétitions{% endcomment %}
    {% for i in (1..4) %}
      {% for block in items %}
        {% assign icon_key = block.settings.icon | default: 'none' %}
        {% assign icon_svg = '' %}
        {% if icon_key == 'truck' %}{% assign icon_svg = icon_truck %}
        {% elsif icon_key == 'clock' %}{% assign icon_svg = icon_clock %}
        {% elsif icon_key == 'star' %}{% assign icon_svg = icon_star %}
        {% elsif icon_key == 'shield' %}{% assign icon_svg = icon_shield %}
        {% elsif icon_key == 'check' %}{% assign icon_svg = icon_check %}
        {% elsif icon_key == 'lightning' %}{% assign icon_svg = icon_lightning %}
        {% elsif icon_key == 'gift' %}{% assign icon_svg = icon_gift %}
        {% endif %}
        <span class="announcement-bar__item"{% if i == 1 %} {{ block.shopify_attributes }}{% endif %}>
          {% if icon_svg != '' %}{{ icon_svg }}{% endif %}{{ block.settings.text }}
        </span>
      {% endfor %}
    {% endfor %}
    {% comment %}Moitié B identique (aria-hidden pour l'accessibilité){% endcomment %}
    {% for i in (1..4) %}
      {% for block in items %}
        {% assign icon_key = block.settings.icon | default: 'none' %}
        {% assign icon_svg = '' %}
        {% if icon_key == 'truck' %}{% assign icon_svg = icon_truck %}
        {% elsif icon_key == 'clock' %}{% assign icon_svg = icon_clock %}
        {% elsif icon_key == 'star' %}{% assign icon_svg = icon_star %}
        {% elsif icon_key == 'shield' %}{% assign icon_svg = icon_shield %}
        {% elsif icon_key == 'check' %}{% assign icon_svg = icon_check %}
        {% elsif icon_key == 'lightning' %}{% assign icon_svg = icon_lightning %}
        {% elsif icon_key == 'gift' %}{% assign icon_svg = icon_gift %}
        {% endif %}
        <span class="announcement-bar__item" aria-hidden="true">
          {% if icon_svg != '' %}{{ icon_svg }}{% endif %}{{ block.settings.text }}
        </span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .announcement-bar {
    overflow: hidden;
    padding: 0.65rem 0;
  }

  .announcement-bar__track {
    display: flex;
    gap: 4rem;
    width: max-content;
    animation: announcement-marquee 25s linear infinite;
    will-change: transform;
  }

  .announcement-bar__item {
    font-size: 0.875rem;
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .announcement-bar__item svg {
    flex-shrink: 0;
    opacity: 0.9;
  }

  @keyframes announcement-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#A855F7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Vitesse (secondes)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "default": "truck",
          "options": [
            { "value": "none",      "label": "Aucune" },
            { "value": "truck",     "label": "🚚 Camion" },
            { "value": "clock",     "label": "🕐 Horloge" },
            { "value": "star",      "label": "⭐ Étoile" },
            { "value": "shield",    "label": "🛡 Bouclier" },
            { "value": "check",     "label": "✓ Coche" },
            { "value": "lightning", "label": "⚡ Éclair" },
            { "value": "gift",      "label": "🎁 Cadeau" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison offerte"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck",  "text": "Livraison offerte" } },
        { "type": "item", "settings": { "icon": "clock",  "text": "Dès 200€ d'achats" } },
        { "type": "item", "settings": { "icon": "lightning", "text": "Expédition en 48 Heures" } }
      ]
    }
  ]
}
{% endschema %}
