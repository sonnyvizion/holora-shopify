{% assign product = all_products[section.settings.product] %}
{% if section.settings.video != blank %}
  {% assign video_url = section.settings.video.sources[0].url %}
{% else %}
  {% assign video_url = 'tripack-scrub.mp4' | asset_url %}
{% endif %}

<div class="prod-hl full-width" id="prod-hl-{{ section.id }}">

  <video
    class="prod-hl__video"
    id="prod-hl-video-{{ section.id }}"
    src="{{ video_url }}"
    muted
    playsinline
    preload="auto"
  ></video>

  <div class="prod-hl__overlay">

    <div class="prod-hl__text-top">
      {% if section.settings.title != blank %}
        <h2 class="prod-hl__title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="prod-hl__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="prod-hl__text-bottom">
      {% if section.settings.description != blank %}
        <p class="prod-hl__desc">{{ section.settings.description }}</p>
      {% endif %}

      <div class="prod-hl__price-wrap">
        {% if section.settings.price_prefix != blank %}
          <span class="prod-hl__price-prefix">{{ section.settings.price_prefix }}</span>
        {% endif %}
        <span class="prod-hl__price">
          {% if product != blank %}
            {{ product.price | money }}
          {% elsif section.settings.price_override != blank %}
            {{ section.settings.price_override }}
          {% endif %}
        </span>
      </div>

      {% assign cta_url = section.settings.cta_url | default: product.url %}
      {% if section.settings.cta_label != blank and cta_url != blank %}
        <a href="{{ cta_url }}" class="prod-hl__cta">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>

  </div>

</div>

{% stylesheet %}
  .prod-hl {
    background: #F5F4F2;
    font-family: 'CircularStd', sans-serif;
    height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* Video centred in section */
  .prod-hl__video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 80%;
    object-fit: contain;
    display: block;
  }

  /* Overlay : text on top of video */
  .prod-hl__overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 2rem 2.5rem;
    text-align: center;
  }

  .prod-hl__text-top {
    flex-shrink: 0;
  }

  .prod-hl__title {
    font-size: 2.8rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #111;
    margin: 0 0 0.35rem;
    line-height: 1.1;
  }

  .prod-hl__subtitle {
    font-size: 1rem;
    font-weight: 500;
    color: #3dba6f;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .prod-hl__text-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .prod-hl__desc {
    font-size: 0.88rem;
    color: #666;
    line-height: 1.2;
    margin: 0;
    max-width: 600px;
  }

  .prod-hl__price-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .prod-hl__price-prefix {
    font-size: 0.95rem;
    font-weight: 400;
    color: #333;
  }

  .prod-hl__price {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #111;
  }

  .prod-hl__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2.2rem;
    border-radius: 999px;
    background: #111;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: background 0.2s;
  }

  .prod-hl__cta:hover {
    background: #333;
  }

  @media (max-width: 768px) {
    .prod-hl {
      height: 80vh;
    }

    .prod-hl__video {
      width: 92%;
      height: 70%;
    }

    .prod-hl__overlay {
      padding: 2rem 1.5rem 2rem;
    }

    .prod-hl__title {
      font-size: 2rem;
    }

    .prod-hl__price {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

<script>
(function() {
  var section = document.getElementById('prod-hl-{{ section.id }}');
  var video   = document.getElementById('prod-hl-video-{{ section.id }}');

  if (!section || !video) return;

  var seekable = false;
  var lastProgress = -1;

  function getProgress() {
    var rect = section.getBoundingClientRect();
    var vh   = window.innerHeight;
    return Math.max(0, Math.min(1, (vh - rect.top) / (vh + section.offsetHeight) * 2));
  }

  // Continuous rAF loop — runs every frame, seeks only when progress changed
  function loop() {
    if (seekable && video.duration) {
      var p = getProgress();
      if (Math.abs(p - lastProgress) > 0.0005) {
        video.currentTime = p * video.duration;
        lastProgress = p;
      }
    }
    requestAnimationFrame(loop);
  }

  // Play→pause unlocks currentTime seeking on all browsers incl. iOS Safari
  function unlock() {
    if (seekable) return;
    var p = video.play();
    if (p && typeof p.then === 'function') {
      p.then(function() {
        video.pause();
        seekable = true;
      }).catch(function() {
        seekable = true;
      });
    } else {
      video.pause();
      seekable = true;
    }
  }

  video.addEventListener('loadedmetadata', unlock);
  video.addEventListener('canplay', unlock);

  // Force loading (needed on iOS which ignores preload="auto")
  video.load();

  requestAnimationFrame(loop);
})();
</script>

{% schema %}
{
  "name": "Product Highlight",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Vidéo scroll",
      "info": "Format recommandé : MP4 H.264, résolution 960×540px, keyframes sur chaque frame (pour scroll fluide), sans audio. Max ~5 MB."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produit"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Ils arrivent !"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Duopack Héros Transcendants"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "price_prefix",
      "label": "Préfixe prix",
      "default": "À partir de"
    },
    {
      "type": "text",
      "id": "price_override",
      "label": "Prix manuel (ex: 59,99 €)",
      "info": "Utilisé si aucun produit n'est sélectionné"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte CTA",
      "default": "Je les veux !"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien CTA (optionnel, sinon lien produit)"
    }
  ],
  "presets": [
    {
      "name": "Product Highlight"
    }
  ]
}
{% endschema %}
