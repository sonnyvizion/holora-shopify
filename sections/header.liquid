<style>
  #shopify-section-{{ section.id }} .site-header__logo-img {
    height: {{ section.settings.logo_height | default: 36 }}px;
  }
</style>

<header class="site-header">
  <div class="site-header__inner">

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, class: 'site-header__logo-img' }}
      {% else %}
        <svg class="site-header__logo-icon" width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="20" stroke="white" stroke-width="2"/>
          <path d="M14 28 C14 20 18 15 22 15 C26 15 30 20 30 28" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
          <line x1="19" y1="28" x2="19" y2="32" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <line x1="25" y1="28" x2="25" y2="32" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
      {% endif %}
    </a>

    <!-- Desktop search bar -->
    <div class="site-header__search" id="desktop-search-wrap">
      <svg class="site-header__search-icon-svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="7.5" cy="7.5" r="6" stroke="white" stroke-width="1.5"/>
        <line x1="12" y1="12" x2="16.5" y2="16.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        id="desktop-search-input"
        class="site-header__search-input"
        placeholder="{{ section.settings.search_placeholder | default: 'Rechercher...' }}"
        aria-label="Rechercher"
        autocomplete="off"
      >
    </div>

    <div class="site-header__actions">
      <!-- Mobile search icon -->
      <button class="site-header__search-btn" id="mobile-search-btn" aria-label="Rechercher">
        <svg width="22" height="22" viewBox="0 0 18 18" fill="none">
          <circle cx="7.5" cy="7.5" r="6" stroke="white" stroke-width="1.5"/>
          <line x1="12" y1="12" x2="16.5" y2="16.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Account icon -->
      <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
         class="site-header__account-btn"
         aria-label="{% if customer %}Mon compte{% else %}Se connecter{% endif %}">
        {% if customer %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="8" r="4" stroke="white" stroke-width="1.5"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="17" cy="17" r="3.5" fill="#22c55e" stroke="rgba(10,10,16,0.98)" stroke-width="1.5"/>
          </svg>
        {% else %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="8" r="4" stroke="white" stroke-width="1.5"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        {% endif %}
      </a>

      <!-- Cart icon -->
      <button class="site-header__cart-btn" id="cart-btn" aria-label="Panier">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 10a4 4 0 01-8 0" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="site-header__cart-count" id="cart-count" style="display:none">0</span>
      </button>

      <!-- Burger -->
      <button class="site-header__burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>
</header>

<!-- Mobile nav backdrop -->
<div id="mobile-nav-backdrop" class="mobile-nav-backdrop"></div>
<div id="mobile-nav-glow" class="mobile-nav-glow"></div>

<!-- Cart drawer -->
<div id="cart-drawer" class="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Mon panier</h2>
    <button class="cart-drawer__close" id="cart-close-btn" aria-label="Fermer">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <line x1="4" y1="4" x2="16" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="16" y1="4" x2="4" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer__body" id="cart-body">
    <div class="cart-drawer__empty" id="cart-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="opacity:0.2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="3" y1="6" x2="21" y2="6" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M16 10a4 4 0 01-8 0" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p>Ton panier est vide</p>
      <a href="/collections" class="cart-drawer__browse">Voir les produits →</a>
    </div>
    <ul class="cart-drawer__items" id="cart-items"></ul>
  </div>

  <div class="cart-drawer__footer" id="cart-footer" style="display:none">
    <div class="cart-drawer__subtotal">
      <span>Sous-total</span>
      <span id="cart-subtotal">—</span>
    </div>
    <p class="cart-drawer__shipping">Livraison calculée à la commande</p>
    <a href="/checkout" class="cart-drawer__checkout" id="cart-checkout">
      Passer la commande
    </a>
    <a href="/cart" class="cart-drawer__view-cart">Voir le panier complet</a>
  </div>
</div>

<!-- Search overlay -->
<div id="search-overlay" class="search-overlay" aria-hidden="true">
  <div class="search-overlay__inner">

    <!-- Mobile input (only visible on mobile) -->
    <div class="search-overlay__mobile-bar">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;opacity:0.5">
        <circle cx="7.5" cy="7.5" r="6" stroke="white" stroke-width="1.5"/>
        <line x1="12" y1="12" x2="16.5" y2="16.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        id="mobile-search-input"
        class="search-overlay__mobile-input"
        placeholder="{{ section.settings.search_placeholder | default: 'Rechercher...' }}"
        autocomplete="off"
        aria-label="Rechercher"
      >
      <button class="search-overlay__close" id="search-close-btn" aria-label="Fermer">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <line x1="4" y1="4" x2="16" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="16" y1="4" x2="4" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Results -->
    <div class="search-overlay__results" id="search-results">
      <div class="search-overlay__empty" id="search-empty">
        <p>Commencez à taper pour rechercher...</p>
      </div>
      <div id="search-collections-wrap" class="search-overlay__group" style="display:none">
        <h3 class="search-overlay__group-title">Collections</h3>
        <div id="search-collections" class="search-overlay__collections"></div>
      </div>
      <div id="search-products-wrap" class="search-overlay__group" style="display:none">
        <h3 class="search-overlay__group-title">Produits</h3>
        <div id="search-products" class="search-overlay__products"></div>
      </div>
      <a id="search-see-all" class="search-overlay__see-all" style="display:none" href="{{ routes.search_url }}">
        Voir tous les résultats →
      </a>
    </div>

  </div>
</div>

<nav id="mobile-nav" class="mobile-nav" aria-hidden="true">
  <ul class="mobile-nav__list">
    {% for link in section.settings.menu.links %}
      <li class="mobile-nav__item">
        {% if link.links.size > 0 %}
          <button class="mobile-nav__link mobile-nav__toggle" aria-expanded="false">
            {{ link.title }}
            <svg class="mobile-nav__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <ul class="mobile-nav__sub">
            {% for sub in link.links %}
              <li><a href="{{ sub.url }}" class="mobile-nav__sub-link">{{ sub.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
  <div class="mobile-nav__footer">
    <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
       class="mobile-nav__account">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="8" r="4" stroke="white" stroke-width="1.5"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        {% if customer %}<circle cx="17" cy="17" r="3.5" fill="#22c55e" stroke="rgba(15,15,15,0.95)" stroke-width="1.5"/>{% endif %}
      </svg>
      <span>{% if customer %}{{ customer.first_name | default: 'Mon compte' }}{% else %}Se connecter{% endif %}</span>
    </a>
  </div>
</nav>

<script>
(function() {
  var overlay      = document.getElementById('search-overlay');
  var desktopInput = document.getElementById('desktop-search-input');
  var mobileInput  = document.getElementById('mobile-search-input');
  var mobilebtn    = document.getElementById('mobile-search-btn');
  var closeBtn     = document.getElementById('search-close-btn');
  var burger       = document.querySelector('.site-header__burger');
  var nav          = document.getElementById('mobile-nav');

  var colWrap      = document.getElementById('search-collections-wrap');
  var colEl        = document.getElementById('search-collections');
  var prodWrap     = document.getElementById('search-products-wrap');
  var prodEl       = document.getElementById('search-products');
  var emptyEl      = document.getElementById('search-empty');
  var seeAll       = document.getElementById('search-see-all');

  var activeInput  = null;
  var debounceTimer;

  // --- Sticky header background + hide on scroll down ---
  var header = document.querySelector('.site-header');
  var lastScrollY = window.scrollY;

  function updateHeaderBg() {
    var scrollY = window.scrollY;

    // Background after hero
    var sections = document.querySelectorAll('.shopify-section');
    var heroEl = null;
    for (var i = 0; i < sections.length; i++) {
      if (sections[i].offsetHeight > 100) { heroEl = sections[i]; break; }
    }
    var threshold = heroEl ? heroEl.offsetHeight : window.innerHeight;
    header.classList.toggle('is-scrolled', scrollY >= threshold);

    // Hide/show on scroll direction (only after 80px from top)
    if (scrollY > 80) {
      header.classList.toggle('is-hidden', scrollY > lastScrollY);
    } else {
      header.classList.remove('is-hidden');
    }

    lastScrollY = scrollY;
  }
  window.addEventListener('scroll', updateHeaderBg, { passive: true });
  updateHeaderBg();


  // --- Open / Close overlay ---
  function openOverlay(input) {
    activeInput = input;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.classList.add('search-open');
    setTimeout(function() { if (input) input.focus(); }, 50);
  }

  function closeOverlay() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('search-open');
    clearResults();
    if (desktopInput) desktopInput.value = '';
    if (mobileInput)  mobileInput.value  = '';
    activeInput = null;
  }

  // --- Burger ---
  var backdrop = document.getElementById('mobile-nav-backdrop');
  var navGlow  = document.getElementById('mobile-nav-glow');

  function closeNav() {
    nav.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    nav.setAttribute('aria-hidden', 'true');
    if (backdrop) backdrop.classList.remove('is-open');
    if (navGlow)  navGlow.classList.remove('is-open');
  }

  if (burger && nav) {
    burger.addEventListener('click', function() {
      var isOpen = nav.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', String(isOpen));
      nav.setAttribute('aria-hidden', String(!isOpen));
      if (isOpen) {
        // Close cart if open
        if (cartDrawer) cartDrawer.classList.remove('is-open');
        if (backdrop) backdrop.classList.add('is-open');
        if (navGlow)  navGlow.classList.add('is-open');
      } else {
        if (backdrop) backdrop.classList.remove('is-open');
        if (navGlow)  navGlow.classList.remove('is-open');
      }
    });
  }

  if (backdrop) {
    backdrop.addEventListener('click', function() {
      closeNav();
      closeCart();
    });
  }

  // --- Cart ---
  var cartDrawer   = document.getElementById('cart-drawer');
  var cartBtn      = document.getElementById('cart-btn');
  var cartCloseBtn = document.getElementById('cart-close-btn');
  var cartCount    = document.getElementById('cart-count');
  var cartItems    = document.getElementById('cart-items');
  var cartEmpty    = document.getElementById('cart-empty');
  var cartFooter   = document.getElementById('cart-footer');
  var cartSubtotal = document.getElementById('cart-subtotal');

  function openCart() {
    // Close nav if open
    if (nav && nav.classList.contains('is-open')) {
      nav.classList.remove('is-open');
      if (burger) burger.setAttribute('aria-expanded', 'false');
      nav.setAttribute('aria-hidden', 'true');
    }
    cartDrawer.classList.add('is-open');
    cartDrawer.setAttribute('aria-hidden', 'false');
    if (backdrop) backdrop.classList.add('is-open');
    fetchCart();
  }

  function closeCart() {
    cartDrawer.classList.remove('is-open');
    cartDrawer.setAttribute('aria-hidden', 'true');
    if (backdrop && !nav.classList.contains('is-open')) {
      backdrop.classList.remove('is-open');
    }
  }

  function fetchCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(renderCart)
      .catch(function() {});
  }

  function renderCart(cart) {
    // Update count badge
    var total = cart.item_count || 0;
    if (cartCount) {
      cartCount.textContent = total;
      cartCount.style.display = total > 0 ? 'flex' : 'none';
    }

    if (!cart.items || cart.items.length === 0) {
      cartEmpty.style.display = 'flex';
      cartItems.style.display = 'none';
      cartFooter.style.display = 'none';
      return;
    }

    cartEmpty.style.display = 'none';
    cartItems.style.display = 'flex';
    cartFooter.style.display = 'flex';

    cartItems.innerHTML = cart.items.map(function(item) {
      var img = item.image
        ? '<img src="' + item.image + '" alt="' + escHtml(item.title) + '" class="cart-item__img" loading="lazy">'
        : '<div class="cart-item__img cart-item__img--placeholder"></div>';
      return '<li class="cart-item" data-key="' + item.key + '">'
        + img
        + '<div class="cart-item__info">'
        + '<span class="cart-item__title">' + escHtml(item.product_title) + '</span>'
        + (item.variant_title && item.variant_title !== 'Default Title'
            ? '<span class="cart-item__variant">' + escHtml(item.variant_title) + '</span>' : '')
        + '<div class="cart-item__row">'
        + '<div class="cart-item__qty">'
        + '<button class="cart-item__qty-btn" data-key="' + item.key + '" data-delta="-1">−</button>'
        + '<span>' + item.quantity + '</span>'
        + '<button class="cart-item__qty-btn" data-key="' + item.key + '" data-delta="1">+</button>'
        + '</div>'
        + '<span class="cart-item__price">' + formatMoney(item.final_line_price) + '</span>'
        + '</div>'
        + '</div>'
        + '<button class="cart-item__remove" data-key="' + item.key + '" aria-label="Supprimer">✕</button>'
        + '</li>';
    }).join('');

    cartSubtotal.textContent = formatMoney(cart.total_price);

    // Qty buttons & remove
    cartItems.querySelectorAll('.cart-item__qty-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = btn.dataset.key;
        var delta = parseInt(btn.dataset.delta);
        var item = cart.items.find(function(i) { return i.key === key; });
        if (!item) return;
        updateCartItem(key, Math.max(0, item.quantity + delta));
      });
    });

    cartItems.querySelectorAll('.cart-item__remove').forEach(function(btn) {
      btn.addEventListener('click', function() {
        updateCartItem(btn.dataset.key, 0);
      });
    });
  }

  function updateCartItem(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(renderCart)
    .catch(function() {});
  }

  // Init count on load
  fetch('/cart.js')
    .then(function(r) { return r.json(); })
    .then(function(cart) {
      var total = cart.item_count || 0;
      if (cartCount) {
        cartCount.textContent = total;
        cartCount.style.display = total > 0 ? 'flex' : 'none';
      }
    });

  if (cartBtn) cartBtn.addEventListener('click', openCart);
  if (cartCloseBtn) cartCloseBtn.addEventListener('click', closeCart);

  // Listen for add-to-cart events from product pages
  document.addEventListener('cart:refresh', fetchCart);

  // --- Mobile nav sub-menus ---
  document.querySelectorAll('.mobile-nav__toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.mobile-nav__item');
      var isOpen = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // --- Mobile search button ---
  if (mobilebtn) {
    mobilebtn.addEventListener('click', function() {
      openOverlay(mobileInput);
    });
  }

  // --- Desktop search focus ---
  if (desktopInput) {
    desktopInput.addEventListener('focus', function() {
      openOverlay(desktopInput);
    });
    desktopInput.addEventListener('input', function() {
      onInput(this.value);
      if (mobileInput) mobileInput.value = this.value;
    });
    desktopInput.addEventListener('keydown', handleKey);
  }

  // --- Mobile input ---
  if (mobileInput) {
    mobileInput.addEventListener('input', function() {
      onInput(this.value);
      if (desktopInput) desktopInput.value = this.value;
    });
    mobileInput.addEventListener('keydown', handleKey);
  }

  // --- Close button ---
  if (closeBtn) closeBtn.addEventListener('click', closeOverlay);

  // --- Click outside ---
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeOverlay();
  });

  // --- Escape key ---
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeOverlay();
  });

  // --- Input handler with debounce ---
  function onInput(q) {
    clearTimeout(debounceTimer);
    q = q.trim();
    if (q.length < 2) {
      clearResults();
      return;
    }
    debounceTimer = setTimeout(function() { fetchSuggestions(q); }, 200);
  }

  function handleKey(e) {
    if (e.key === 'Enter') {
      var q = (activeInput || e.target).value.trim();
      if (q) window.location.href = '{{ routes.search_url }}?q=' + encodeURIComponent(q) + '&type=product';
    }
  }

  // --- Fetch predictive search ---
  function fetchSuggestions(q) {
    var url = '/search/suggest.json?q=' + encodeURIComponent(q)
      + '&resources[type]=collection,product'
      + '&resources[limit]=5'
      + '&resources[options][unavailable_products]=last';

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) { renderResults(data, q); })
      .catch(function() {});
  }

  // --- Render results ---
  function renderResults(data, q) {
    var results    = data.resources && data.resources.results || {};
    var collections = results.collections || [];
    var products    = results.products    || [];

    var hasResults = collections.length > 0 || products.length > 0;
    emptyEl.style.display = hasResults ? 'none' : 'block';
    emptyEl.querySelector('p').textContent = hasResults ? '' : 'Aucun résultat pour "' + q + '"';

    // Collections
    if (collections.length > 0) {
      colEl.innerHTML = collections.map(function(c) {
        var img = c.featured_image
          ? '<img src="' + c.featured_image.url + '" alt="' + escHtml(c.title) + '" class="sr-col__img" loading="lazy">'
          : '<div class="sr-col__img sr-col__img--placeholder"></div>';
        return '<a href="' + c.url + '" class="sr-col">'
          + img
          + '<span class="sr-col__title">' + escHtml(c.title) + '</span>'
          + '</a>';
      }).join('');
      colWrap.style.display = '';
    } else {
      colWrap.style.display = 'none';
    }

    // Products
    if (products.length > 0) {
      prodEl.innerHTML = products.map(function(p) {
        var img = p.featured_image
          ? '<img src="' + p.featured_image.url + '" alt="' + escHtml(p.title) + '" class="sr-prod__img" loading="lazy">'
          : '<div class="sr-prod__img sr-prod__img--placeholder"></div>';
        var price = p.price ? formatMoney(p.price) : '';
        return '<a href="' + p.url + '" class="sr-prod">'
          + img
          + '<div class="sr-prod__info">'
          + '<span class="sr-prod__title">' + escHtml(p.title) + '</span>'
          + (price ? '<span class="sr-prod__price">' + price + '</span>' : '')
          + '</div>'
          + '</a>';
      }).join('');
      prodWrap.style.display = '';
    } else {
      prodWrap.style.display = 'none';
    }

    // See all link
    if (hasResults) {
      seeAll.href = '{{ routes.search_url }}?q=' + encodeURIComponent(q) + '&type=product';
      seeAll.style.display = '';
    } else {
      seeAll.style.display = 'none';
    }
  }

  function clearResults() {
    colWrap.style.display  = 'none';
    prodWrap.style.display = 'none';
    seeAll.style.display   = 'none';
    emptyEl.style.display  = 'block';
    emptyEl.querySelector('p').textContent = 'Commencez à taper pour rechercher...';
    colEl.innerHTML  = '';
    prodEl.innerHTML = '';
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatMoney(cents) {
    return (cents / 100).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' });
  }
})();
</script>

{% stylesheet %}
  /* ---- Header ---- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    padding: 1.25rem 2rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .site-header.is-scrolled {
    background: #242427;
  }

  .site-header__logo,
  .site-header__actions {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .site-header.is-hidden .site-header__logo,
  .site-header.is-hidden .site-header__actions {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
  }

  .site-header.is-scrolled.is-hidden {
    background: transparent;
  }

  @media (max-width: 768px) {
    .site-header.is-hidden .site-header__logo,
    .site-header.is-hidden .site-header__actions {
      transform: none;
    }
    .site-header.is-hidden {
      transform: translateY(-100%);
    }
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    justify-self: start;
  }

  .site-header__logo-img {
    height: 36px;
    width: auto;
  }

  /* Desktop search */
  .site-header__search {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 999px;
    padding: 0.5rem 1.25rem;
    gap: 0.5rem;
    width: 360px;
    backdrop-filter: blur(10px);
    cursor: text;
    transition: background 0.2s, border-color 0.2s;
  }

  .site-header__search:focus-within {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.5);
  }

  .site-header__search-icon-svg {
    flex-shrink: 0;
  }

  .site-header__search-input {
    background: none;
    border: none;
    outline: none;
    color: #fff;
    font-size: 0.95rem;
    font-family: 'CircularStd', sans-serif;
    width: 100%;
  }

  .site-header__search-input::placeholder {
    color: rgba(255,255,255,0.6);
  }

  /* Actions (mobile icon + burger) */
  .site-header__actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-header__search-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: none;
    align-items: center;
    padding: 4px;
  }

  .site-header__burger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .site-header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  .site-header__burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .site-header__burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .site-header__burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---- Search overlay ---- */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 199;
    background: rgba(8,8,12,0);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, background 0.25s ease;
    overflow-y: auto;
  }

  .search-overlay.is-open {
    background: rgba(8,8,12,0.97);
    pointer-events: all;
    opacity: 1;
    visibility: visible;
  }

  .search-overlay__inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 7rem 2rem 3rem;
  }

  /* Mobile bar (hidden on desktop) */
  .search-overlay__mobile-bar {
    display: none;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 999px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2.5rem;
  }

  .search-overlay__mobile-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 1.05rem;
    font-family: 'CircularStd', sans-serif;
    color: #fff;
    min-width: 0;
  }

  .search-overlay__mobile-input::placeholder {
    color: rgba(255,255,255,0.35);
  }

  .search-overlay__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .search-overlay__close:hover { opacity: 1; }

  /* Results */
  .search-overlay__empty {
    font-size: 0.95rem;
    padding: 1rem 0;
    color: rgba(255,255,255,0.35);
  }

  .search-overlay__empty p { margin: 0; }

  .search-overlay__group {
    margin-bottom: 2.5rem;
  }

  .search-overlay__group-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin: 0 0 0.9rem;
  }

  /* Collection results */
  .search-overlay__collections {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .sr-col {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 0.4rem 1rem 0.4rem 0.4rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .sr-col:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.2);
  }

  .sr-col__img {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .sr-col__img--placeholder {
    background: rgba(255,255,255,0.1);
  }

  .sr-col__title {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
  }

  /* Product results */
  .search-overlay__products {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sr-prod {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .sr-prod:hover { background: rgba(255,255,255,0.06); }

  .sr-prod__img {
    width: 52px;
    height: 52px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255,255,255,0.05);
  }

  .sr-prod__img--placeholder {
    background: rgba(255,255,255,0.08);
  }

  .sr-prod__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sr-prod__title {
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .sr-prod__price {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.45);
  }

  /* See all */
  .search-overlay__see-all {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #a78bfa;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .search-overlay__see-all:hover { color: #c4b5fd; }

  /* ---- Account button ---- */
  .site-header__account-btn {
    display: flex;
    align-items: center;
    padding: 4px;
    position: relative;
    opacity: 0.85;
    transition: opacity 0.15s;
  }

  .site-header__account-btn:hover { opacity: 1; }

  /* ---- Cart button ---- */
  .site-header__cart-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 4px;
    position: relative;
  }

  .site-header__cart-count {
    position: absolute;
    top: -2px;
    right: -4px;
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'CircularStd', sans-serif;
    line-height: 1;
  }

  /* ---- Cart drawer ---- */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(420px, 92vw);
    background: rgba(10,10,16,0.98);
    backdrop-filter: blur(24px);
    z-index: 210;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
    font-family: 'CircularStd', sans-serif;
    border-left: 1px solid rgba(255,255,255,0.07);
  }

  .cart-drawer.is-open { transform: translateX(0); }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5.5rem 1.5rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .cart-drawer__title {
    font-size: 1.1rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .cart-drawer__close:hover { opacity: 1; }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    scrollbar-width: none;
  }

  .cart-drawer__body::-webkit-scrollbar { display: none; }

  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    height: 100%;
    text-align: center;
  }

  .cart-drawer__empty p {
    color: rgba(255,255,255,0.35);
    font-size: 0.95rem;
    margin: 0;
  }

  .cart-drawer__browse {
    color: #a78bfa;
    font-size: 0.9rem;
    text-decoration: none;
    font-weight: 500;
  }

  .cart-drawer__browse:hover { color: #c4b5fd; }

  .cart-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    position: relative;
  }

  .cart-item__img {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255,255,255,0.07);
  }

  .cart-item__img--placeholder {
    background: rgba(255,255,255,0.07);
  }

  .cart-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .cart-item__title {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.3;
    display: block;
  }

  .cart-item__variant {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    display: block;
  }

  .cart-item__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.4rem;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.07);
    border-radius: 999px;
    padding: 0.25rem 0.6rem;
    font-size: 0.85rem;
    color: #fff;
  }

  .cart-item__qty-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
    line-height: 1;
    transition: color 0.15s;
  }

  .cart-item__qty-btn:hover { color: #fff; }

  .cart-item__price {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .cart-item__remove {
    background: none;
    border: none;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    font-size: 0.75rem;
    padding: 4px;
    transition: color 0.15s;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .cart-item__remove:hover { color: rgba(255,255,255,0.7); }

  .cart-drawer__footer {
    flex-shrink: 0;
    padding: 1.25rem 1.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .cart-drawer__shipping {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    margin: 0;
  }

  @keyframes cart-checkout-glow {
    0%   { box-shadow: 0 0 0 0 rgba(167,139,250,0), 0 0 0 0 rgba(124,58,237,0); }
    50%  { box-shadow: 0 0 20px 5px rgba(167,139,250,0.45), 0 0 45px 12px rgba(124,58,237,0.15); }
    100% { box-shadow: 0 0 0 0 rgba(167,139,250,0), 0 0 0 0 rgba(124,58,237,0); }
  }

  .cart-drawer__checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.5rem;
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: #fff;
    border-radius: 14px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    animation: cart-checkout-glow 2.4s ease-in-out infinite;
    transition: background 0.2s;
  }

  .cart-drawer__checkout:hover { background: linear-gradient(135deg, #b87ef0, #8b4cf7); }

  .cart-drawer__view-cart {
    display: block;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .cart-drawer__view-cart:hover { color: rgba(255,255,255,0.7); }

  /* ---- Mobile nav ---- */
  .mobile-nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0,0,0,0);
    pointer-events: none;
    transition: background 0.3s ease;
  }

  .mobile-nav-backdrop.is-open {
    background: rgba(0,0,0,0.4);
    pointer-events: all;
  }

  .mobile-nav-glow { display: none; }

  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(320px, 85vw);
    background: rgba(15,15,15,0.95);
    backdrop-filter: blur(20px);
    z-index: 160;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    padding: 6rem 2rem 6rem;
    overflow-y: auto;
    scrollbar-width: none;
  }

  .mobile-nav::-webkit-scrollbar { display: none; }


  .mobile-nav.is-open {
    transform: translateX(0);
    box-shadow: -2px 0 0 rgba(167,139,250,0.5), -12px 0 35px rgba(124,58,237,0.5), -30px 0 60px rgba(109,40,217,0.2);
  }

  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-nav__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    cursor: pointer;
    text-align: left;
    font-family: 'CircularStd', sans-serif;
    letter-spacing: inherit;
  }

  .mobile-nav__link:hover { color: rgba(255,255,255,0.7); }

  .mobile-nav__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
    opacity: 0.5;
  }

  .mobile-nav__item.is-open .mobile-nav__chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  .mobile-nav__sub {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }

  .mobile-nav__item.is-open .mobile-nav__sub {
    max-height: 600px;
  }

  .mobile-nav__sub-link {
    display: block;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 400;
    padding: 0.6rem 0 0.6rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: color 0.15s;
  }

  .mobile-nav__sub-link:hover { color: #fff; }

  .mobile-nav__footer {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    right: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.25rem;
  }

  .mobile-nav__account {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .mobile-nav__account:hover { color: #fff; }

  /* body lock when search open */
  body.search-open { overflow: hidden; }

  /* On desktop: keep header visible (search bar stays + glows), hide only nav links */
  body.search-open .site-header__logo,
  body.search-open .site-header__actions {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .site-header__logo,
  .site-header__actions {
    transition: opacity 0.2s ease;
  }

  /* On mobile: hide whole header */
  @media (max-width: 768px) {
    body.search-open .site-header {
      opacity: 0;
      pointer-events: none;
    }
    body.search-open .site-header__logo,
    body.search-open .site-header__actions {
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* Glow aura on search inputs when overlay is open */
  @keyframes search-glow {
    0%   { box-shadow: 0 0 0 0 rgba(167,139,250,0), 0 0 0 0 rgba(202,148,249,0); }
    50%  { box-shadow: 0 0 18px 4px rgba(167,139,250,0.55), 0 0 40px 10px rgba(124,58,237,0.2); }
    100% { box-shadow: 0 0 0 0 rgba(167,139,250,0), 0 0 0 0 rgba(202,148,249,0); }
  }

  body.search-open .site-header__search {
    animation: search-glow 2.2s ease-in-out infinite;
    border-color: rgba(167,139,250,0.6) !important;
  }

  .search-overlay.is-open .search-overlay__mobile-bar {
    animation: search-glow 2.2s ease-in-out infinite;
    border-color: rgba(167,139,250,0.6) !important;
  }

  /* ---- Responsive ---- */
  @media (min-width: 769px) {
    .site-header__search-btn {
      display: none !important;
    }
    .search-overlay__mobile-bar {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    .site-header__account-btn {
      display: none !important;
    }

    .site-header__inner {
      grid-template-columns: 1fr auto;
    }

    .site-header__search {
      display: none !important;
    }

    .site-header__search-btn {
      display: flex;
    }

    .search-overlay__mobile-bar {
      display: flex;
    }

    .search-overlay__inner {
      padding: 1.5rem 1.25rem 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Hauteur du logo",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Placeholder recherche",
      "default": "Rechercher..."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    }
  ]
}
{% endschema %}
