<header class="site-header">
  <div class="site-header__inner">

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 80 | image_tag: alt: shop.name, class: 'site-header__logo-img' }}
      {% else %}
        <svg class="site-header__logo-icon" width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="20" stroke="white" stroke-width="2"/>
          <path d="M14 28 C14 20 18 15 22 15 C26 15 30 20 30 28" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
          <line x1="19" y1="28" x2="19" y2="32" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <line x1="25" y1="28" x2="25" y2="32" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
      {% endif %}
    </a>

    <form action="{{ routes.search_url }}" method="get" class="site-header__search" role="search">
      <button type="submit" class="site-header__search-icon" aria-label="Rechercher">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="7.5" cy="7.5" r="6" stroke="white" stroke-width="1.5"/>
          <line x1="12" y1="12" x2="16.5" y2="16.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <input
        type="search"
        name="q"
        class="site-header__search-input"
        placeholder="{{ section.settings.search_placeholder | default: 'Tapez votre recherche ...' }}"
        aria-label="Rechercher"
        value="{{ search.terms | escape }}"
      >
    </form>

    <button class="site-header__burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<nav id="mobile-nav" class="mobile-nav" aria-hidden="true">
  <ul class="mobile-nav__list">
    {% for link in section.settings.menu.links %}
      <li><a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
</nav>

<script>
  (function() {
    var burger = document.querySelector('.site-header__burger');
    var nav = document.getElementById('mobile-nav');
    if (!burger || !nav) return;
    burger.addEventListener('click', function() {
      var isOpen = nav.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', isOpen);
      nav.setAttribute('aria-hidden', !isOpen);
    });
  })();
</script>

{% stylesheet %}
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    justify-self: start;
  }

  .site-header__logo-img {
    width: 48px;
    height: auto;
    border-radius: 50%;
  }

  .site-header__search {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 999px;
    padding: 0.5rem 1.25rem;
    gap: 0.5rem;
    width: 380px;
    backdrop-filter: blur(10px);
    transition: background 0.2s, border-color 0.2s;
  }

  .site-header__search:focus-within {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.5);
  }

  .site-header__search-icon {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .site-header__search-input {
    background: none;
    border: none;
    outline: none;
    color: #fff;
    font-size: 0.95rem;
    width: 100%;
  }

  .site-header__search-input::placeholder {
    color: rgba(255,255,255,0.6);
  }

  .site-header__burger {
    justify-self: end;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .site-header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(320px, 85vw);
    background: rgba(15,15,15,0.95);
    backdrop-filter: blur(20px);
    z-index: 99;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    padding: 6rem 2rem 2rem;
  }

  .mobile-nav.is-open {
    transform: translateX(0);
  }

  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-nav__link {
    display: block;
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .mobile-nav__link:hover {
    color: rgba(255,255,255,0.7);
  }

  @media (max-width: 640px) {
    .site-header__search {
      width: 200px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Placeholder recherche",
      "default": "Tapez votre recherche ..."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    }
  ]
}
{% endschema %}
